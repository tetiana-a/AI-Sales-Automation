      "parameters": {
        "jsCode": "// Filter: transcript >20 chars, take last 10 not yet analyzed\nconst rows = $input.all().map(i => i.json);\nconst valid = rows.filter(r => String(r.transcript || '').length > 20);\nconst last10 = valid.slice(-10);\nreturn last10.map(r => ({ json: r }));"
      },
