    {
      "parameters": {
        "jsCode": "// Parse AI output JSON safely\nconst raw = $input.first().json?.output || JSON.stringify($input.first().json);\nlet parsed = {};\ntry {\n  const clean = raw.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(clean);\n} catch(e) {\n  parsed = { raw_output: raw, parse_error: e.message };\n}\nreturn [{ json: parsed }];"
      },
